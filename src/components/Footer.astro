---
import Icon from "./Icon.astro";
import { i18n, type Lang } from "../data/i18n";

type Props = { lang?: Lang };
const { lang = "en" } = Astro.props;
const t = i18n[lang].footer;
const year = new Date().getFullYear();

const socials = [
  { label: "GitHub", handle: "@MackDing", href: "https://github.com/MackDing", icon: "github" },
  { label: "Telegram", handle: "@MackClaws", href: "https://t.me/MackClaws", icon: "telegram" },
  { label: "Email", handle: "hi@claws.ltd", href: "mailto:hi@claws.ltd", icon: "mail" },
] as const;
---

<footer id="contact" class="relative mt-8 border-t border-[color:var(--color-border)] scroll-mt-20">
  <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-[color:var(--color-accent-glow)] to-transparent" aria-hidden="true"></div>

  <div class="container-page py-16 md:py-20">
    <div class="grid gap-10 md:grid-cols-[1.4fr_1fr_1fr]">
      <div class="max-w-sm">
        <a href={lang === "zh" ? "/zh/" : "/"} class="font-display text-base font-semibold tracking-tight text-[color:var(--color-fg)]">
          mack<span class="text-[color:var(--color-accent-bright)]">.dev</span>
        </a>
        <p class="mt-4 text-sm leading-relaxed text-[color:var(--color-fg-muted)] text-pretty">
          {t.tagline}
        </p>
      </div>

      <div>
        <h4 class="font-mono text-[11px] uppercase tracking-[0.08em] text-[color:var(--color-fg-subtle)]">
          {t.elsewhere}
        </h4>
        <ul class="mt-4 space-y-3">
          {socials.map((s) => (
            <li>
              <a
                href={s.href}
                target={s.href.startsWith("http") ? "_blank" : undefined}
                rel={s.href.startsWith("http") ? "noopener noreferrer" : undefined}
                class="group inline-flex items-center gap-2.5 text-sm text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-fg)] transition-colors"
              >
                <Icon name={s.icon} size={15} class="text-[color:var(--color-fg-subtle)] group-hover:text-[color:var(--color-accent-bright)] transition-colors" />
                <span>{s.label}</span>
                <span class="font-mono text-[12px] text-[color:var(--color-fg-subtle)]">{s.handle}</span>
              </a>
            </li>
          ))}
        </ul>
      </div>

      <div>
        <h4 class="font-mono text-[11px] uppercase tracking-[0.08em] text-[color:var(--color-fg-subtle)]">
          {t.thisSite}
        </h4>
        <ul class="mt-4 space-y-3 text-sm text-[color:var(--color-fg-muted)]">
          <li>
            <a href="#projects" class="hover:text-[color:var(--color-fg)] transition-colors">{t.links.projects}</a>
          </li>
          <li>
            <a href="#upstream" class="hover:text-[color:var(--color-fg)] transition-colors">{t.links.upstream}</a>
          </li>
          <li>
            <a
              href="https://github.com/MackDing"
              target="_blank"
              rel="noopener noreferrer"
              class="hover:text-[color:var(--color-fg)] transition-colors"
            >
              {t.links.source}
            </a>
          </li>
        </ul>
      </div>
    </div>

    <div class="mt-14 pt-6 border-t border-[color:var(--color-border)] flex flex-wrap items-center justify-between gap-3 text-[12px] text-[color:var(--color-fg-subtle)] font-mono">
      <span>&copy; {year} Mack Ding. {t.rights}</span>
      <span>{t.credits}</span>
    </div>
  </div>
</footer>
