---
import Icon from "./Icon.astro";
import LangToggle from "./LangToggle.astro";
import { i18n, type Lang } from "../data/i18n";

type Props = { lang?: Lang };
const { lang = "en" } = Astro.props;
const t = i18n[lang];
---

<section class="relative overflow-hidden bg-gradient-hero">
  <div class="absolute inset-0 -z-10 opacity-[0.08]" aria-hidden="true">
    <svg xmlns="http://www.w3.org/2000/svg" width="100%" height="100%">
      <defs>
        <pattern id="grid" width="44" height="44" patternUnits="userSpaceOnUse">
          <path d="M44 0H0V44" fill="none" stroke="white" stroke-width="0.5" />
        </pattern>
      </defs>
      <rect width="100%" height="100%" fill="url(#grid)" />
    </svg>
  </div>

  <div class="hero-edge-bleed hero-edge-bleed--left" aria-hidden="true"></div>
  <div class="hero-edge-bleed hero-edge-bleed--right" aria-hidden="true"></div>

  <div class="container-page pt-28 pb-24 md:pt-36 md:pb-32 relative">
    <nav class="absolute top-6 inset-x-0 container-page flex items-center justify-between gap-3" aria-label="Primary">
      <a href={lang === "zh" ? "/zh/" : "/"} class="font-display text-[15px] font-semibold tracking-tight text-[color:var(--color-fg)]">
        mack<span class="text-[color:var(--color-accent-bright)]">.dev</span>
      </a>
      <div class="flex items-center gap-1 text-sm">
        <a href="#projects" class="hidden sm:inline-flex px-3 py-1.5 rounded-md text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-fg)] transition-colors">{t.nav.projects}</a>
        <a href="#upstream" class="hidden sm:inline-flex px-3 py-1.5 rounded-md text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-fg)] transition-colors">{t.nav.contributions}</a>
        <a href="#contact" class="hidden sm:inline-flex px-3 py-1.5 rounded-md text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-fg)] transition-colors">{t.nav.contact}</a>
        <span class="hidden sm:inline-block w-px h-4 bg-[color:var(--color-border)] mx-1.5" aria-hidden="true"></span>
        <LangToggle lang={lang} />
        <a
          href="https://github.com/MackDing"
          target="_blank"
          rel="noopener noreferrer"
          aria-label={t.nav.githubAria}
          class="inline-flex items-center justify-center w-9 h-9 rounded-md text-[color:var(--color-fg-muted)] hover:text-[color:var(--color-fg)] hover:bg-[color:var(--color-surface-hover)] transition-colors ml-1"
        >
          <Icon name="github" size={16} />
        </a>
      </div>
    </nav>

    <div class="max-w-3xl">
      <div class="reveal reveal-1 inline-flex items-center gap-2 px-2.5 py-1 rounded-full border border-[color:var(--color-border)] bg-[color:var(--color-surface)] text-[11px] font-medium text-[color:var(--color-fg-muted)]">
        <span class="relative flex h-1.5 w-1.5">
          <span class="absolute inline-flex h-full w-full rounded-full bg-[color:var(--color-accent-bright)] opacity-75 animate-ping"></span>
          <span class="relative inline-flex rounded-full h-1.5 w-1.5 bg-[color:var(--color-accent-bright)]"></span>
        </span>
        <span class="font-mono tracking-wide">{t.hero.badge}</span>
      </div>

      <h1 class="reveal reveal-2 mt-6 font-display font-semibold text-[44px] leading-[1.05] tracking-[-0.03em] text-[color:var(--color-fg)] md:text-[72px] text-balance">
        {t.hero.titleLine1}<br />
        <span class="text-[color:var(--color-fg-muted)]">{t.hero.titleLine2}</span>
        <span class="block text-[color:var(--color-fg-muted)]">
          {t.hero.titleLine3a}
          <span class="text-[color:var(--color-fg)] whitespace-nowrap">{t.hero.titleLine3b}</span>
          {t.hero.titleLine3c}
          <span class="text-[color:var(--color-fg)] whitespace-nowrap">{t.hero.titleLine3d}</span>.
        </span>
      </h1>

      <p class="reveal reveal-3 mt-7 max-w-xl text-[17px] leading-relaxed text-[color:var(--color-fg-muted)] text-pretty">
        {t.hero.sub}
      </p>

      <div class="reveal reveal-4 mt-9 flex flex-wrap items-center gap-3">
        <a
          href="https://github.com/MackDing"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-primary"
        >
          <Icon name="github" size={16} />
          {t.hero.ctaGithub}
          <Icon name="arrow-up-right" size={14} />
        </a>
        <a
          href="https://t.me/MackClaws"
          target="_blank"
          rel="noopener noreferrer"
          class="btn btn-ghost"
        >
          <Icon name="telegram" size={16} />
          {t.hero.ctaHi}
        </a>
      </div>

      <a
        href="#projects"
        id="scroll-hint"
        class="scroll-hint mt-10 inline-flex flex-col items-center gap-1.5 text-[11px] font-mono uppercase tracking-[0.12em] text-[color:var(--color-fg-subtle)] hover:text-[color:var(--color-fg-muted)] transition-colors"
        aria-label={t.hero.scrollAria}
      >
        <span>{t.hero.scroll}</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="m6 9 6 6 6-6" />
        </svg>
      </a>
    </div>
  </div>

  <div class="h-px bg-gradient-to-r from-transparent via-[color:var(--color-border-strong)] to-transparent"></div>
</section>

<script is:inline>
  (() => {
    const hint = document.getElementById("scroll-hint");
    if (!hint) return;
    let hidden = false;
    const onScroll = () => {
      if (!hidden && window.scrollY > 200) {
        hint.dataset.hidden = "true";
        hidden = true;
        window.removeEventListener("scroll", onScroll);
      }
    };
    window.addEventListener("scroll", onScroll, { passive: true });
  })();
</script>
