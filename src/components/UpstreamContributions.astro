---
import Icon from "./Icon.astro";
import { i18n, type Lang } from "../data/i18n";

type Props = { lang?: Lang };
const { lang = "en" } = Astro.props;
const t = i18n[lang];

const contributions = [
  {
    project: "OpenClaw",
    title: "feat(onboard): add custom/local API configuration flow",
    prNumber: 11106,
    url: "https://github.com/openclaw/openclaw/pull/11106",
    status: t.upstream.statusMerged,
    mergedLine: t.upstream.openclaw.mergedLine,
    summary: t.upstream.openclaw.summary,
  },
  {
    project: "JackClawOS",
    title:
      "feat: gstack methodology fusion \u2014 7 AI team nodes with professional workflows",
    prNumber: 12,
    url: "https://github.com/DevJackKong/JackClawOS/pull/12",
    status: t.upstream.statusMerged,
    mergedLine: t.upstream.jackclaw.mergedLine,
    summary: t.upstream.jackclaw.summary,
  },
];
---

<section id="upstream" class="relative py-20 md:py-24 scroll-mt-20">
  <div class="container-page">
    <div class="max-w-2xl">
      <span class="section-eyebrow"><span class="chip-dot bg-[color:var(--color-accent-bright)]"></span>{t.upstream.eyebrow}</span>
      <h2 class="section-title mt-4 text-3xl md:text-4xl text-balance">
        {t.upstream.title}
      </h2>
      <p class="mt-4 text-[color:var(--color-fg-muted)] text-pretty leading-relaxed">
        {t.upstream.body}
      </p>
    </div>

    <ul class="mt-12 grid gap-4 md:grid-cols-2">
      {contributions.map((c) => (
        <li>
          <a
            href={c.url}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={t.upstream.cardAria(c.project, c.prNumber)}
            class="card card-interactive group relative flex flex-col p-6 h-full focus:outline-none focus-visible:outline-[color:var(--color-accent-bright)]"
          >
            <div class="flex items-center justify-between gap-3">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="chip">
                  <span class="chip-dot bg-[color:var(--color-accent-bright)]"></span>
                  <span class="text-[color:var(--color-fg)]">{c.project}</span>
                </span>
                <span class="chip chip-merged">
                  <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.25" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
                    <circle cx="18" cy="18" r="3" />
                    <circle cx="6" cy="6" r="3" />
                    <path d="M6 21V9a9 9 0 0 0 9 9" />
                  </svg>
                  <span>{c.status}</span>
                </span>
              </div>
              <span class="shrink-0 inline-flex items-center justify-center w-7 h-7 rounded-md text-[color:var(--color-fg-subtle)] group-hover:text-[color:var(--color-fg)] transition-colors">
                <Icon name="arrow-up-right" size={14} />
              </span>
            </div>

            <div class="mt-5 flex items-start gap-3">
              <span class="shrink-0 inline-flex items-center justify-center w-9 h-9 rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface)] text-[color:var(--color-accent-bright)]">
                <Icon name="git-pull-request" size={16} />
              </span>
              <div class="min-w-0">
                <h3 class="font-display font-semibold text-[color:var(--color-fg)] tracking-tight leading-snug">
                  {c.title}
                </h3>
                <p class="mt-1 font-mono text-[12px] text-[color:var(--color-fg-subtle)]">
                  {c.project.toLowerCase()}#{c.prNumber} &middot; {c.mergedLine}
                </p>
              </div>
            </div>

            <p class="mt-4 text-[14px] leading-relaxed text-[color:var(--color-fg-muted)] text-pretty">
              {c.summary}
            </p>
          </a>
        </li>
      ))}
    </ul>
  </div>
</section>
