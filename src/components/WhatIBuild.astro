---
import Icon from "./Icon.astro";
import { i18n, type Lang } from "../data/i18n";

type Props = { lang?: Lang };
const { lang = "en" } = Astro.props;
const t = i18n[lang].whatIBuild;
---

<section class="relative py-24 md:py-28">
  <div class="container-page">
    <div class="max-w-2xl">
      <span class="section-eyebrow reveal reveal-1"><span class="chip-dot bg-[color:var(--color-accent-bright)]"></span>{t.eyebrow}</span>
      <h2 class="section-title reveal reveal-2 mt-4 text-3xl md:text-4xl text-balance">
        {t.title}
      </h2>
      <p class="reveal reveal-3 mt-5 text-[color:var(--color-fg-muted)] text-pretty leading-relaxed">
        {t.body}
      </p>
    </div>

    <div class="mt-12 grid gap-4 md:grid-cols-3">
      {t.pillars.map((p, i) => (
        <div class={`card p-5 reveal reveal-${i + 2}`}>
          <div class="inline-flex items-center justify-center w-9 h-9 rounded-lg border border-[color:var(--color-border)] bg-[color:var(--color-surface)] text-[color:var(--color-accent-bright)]">
            <Icon name={p.icon as any} size={18} />
          </div>
          <h3 class="mt-4 font-display font-semibold text-[color:var(--color-fg)] tracking-tight">{p.title}</h3>
          <p class="mt-1.5 text-sm leading-relaxed text-[color:var(--color-fg-muted)]" set:html={p.body}></p>
        </div>
      ))}
    </div>
  </div>
</section>
