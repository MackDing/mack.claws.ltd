---
import "../styles/global.css";
import Starfield from "../components/Starfield.astro";
import { i18n, type Lang } from "../data/i18n";

type Props = {
  lang?: Lang;
  title?: string;
  description?: string;
};

const { lang = "en", title, description } = Astro.props;
const t = i18n[lang];
const metaTitle = title ?? t.meta.title;
const metaDescription = description ?? t.meta.description;

const site = "https://mack.claws.ltd";
const canonical = new URL(Astro.url.pathname, site).href;
const enUrl = new URL("/", site).href;
const zhUrl = new URL("/zh/", site).href;
const ogImage = new URL("/og-image.png", site).href;
---

<!doctype html>
<html lang={t.htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <script is:inline>
      (function () {
        try {
          var KEY = "mack-portal-lang";
          var path = window.location.pathname;
          var isZh = path === "/zh/" || path === "/zh" || path.indexOf("/zh/") === 0;
          var stored = null;
          try { stored = localStorage.getItem(KEY); } catch (e) {}
          if (stored === null) {
            var nav = ((navigator.language || navigator.userLanguage || "") + "").toLowerCase();
            if (nav.indexOf("zh") === 0 && !isZh) {
              try { localStorage.setItem(KEY, "zh"); } catch (e) {}
              window.location.replace("/zh/");
              return;
            }
          }
          try { localStorage.setItem(KEY, isZh ? "zh" : "en"); } catch (e) {}
        } catch (e) {}
      })();
    </script>
    <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover" />
    <meta name="color-scheme" content="dark" />
    <meta name="theme-color" content="#07080B" />
    <meta name="generator" content={Astro.generator} />

    <title>{metaTitle}</title>
    <meta name="description" content={metaDescription} />
    <meta name="author" content="Mack Ding" />

    <meta property="og:site_name" content="mack.dev" />
    <meta property="og:title" content={metaTitle} />
    <meta property="og:description" content={metaDescription} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical} />
    <meta property="og:locale" content={lang === "zh" ? "zh_CN" : "en_US"} />
    <meta property="og:locale:alternate" content={lang === "zh" ? "en_US" : "zh_CN"} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="mack.dev — Mack Ding: small, honest tools for AI agents and developers." />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={metaTitle} />
    <meta name="twitter:description" content={metaDescription} />
    <meta name="twitter:image" content={ogImage} />
    <meta name="twitter:image:alt" content="mack.dev — Mack Ding: small, honest tools for AI agents and developers." />
    <meta name="twitter:creator" content="@MackClaws" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/favicon-180.png" />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" hreflang="en" href={enUrl} />
    <link rel="alternate" hreflang="zh-Hans" href={zhUrl} />
    <link rel="alternate" hreflang="x-default" href={enUrl} />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Space+Grotesk:wght@500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
    />
  </head>
  <body class="min-h-screen antialiased">
    <Starfield />
    <div class="bg-vertical-overlay" aria-hidden="true"></div>
    <a
      href="#main"
      class="sr-only focus:not-sr-only focus:fixed focus:top-4 focus:left-4 focus:z-50 focus:btn focus:btn-primary"
    >
      {t.skip}
    </a>
    <slot />
    <script is:inline>
      document.addEventListener("click", function (e) {
        var el = e.target;
        while (el && el !== document.body) {
          if (el.dataset && el.dataset.cardAction !== undefined) {
            e.stopPropagation();
            return;
          }
          el = el.parentElement;
        }
      }, true);
    </script>
  </body>
</html>
